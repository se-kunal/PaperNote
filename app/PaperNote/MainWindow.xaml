<Window x:Class="PaperNote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PaperNote.ViewModels"
        xmlns:views="clr-namespace:PaperNote.Views"
        mc:Ignorable="d"
        Title="PaperNote" Height="780" Width="1200" MinHeight="500" MinWidth="800"
        Icon="Assets/app.ico"
        WindowStyle="None"
        FontFamily="{StaticResource UiFont}"
        Background="{DynamicResource PaperBrush}"
        Foreground="{DynamicResource InkBrush}"
        Opacity="0"
        KeyDown="OnWindowKeyDown">

    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.20"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewNoteCommand}"/>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FocusSearchCommand}"/>
        <KeyBinding Key="K" Modifiers="Control" Command="{Binding OpenPaletteCommand}"/>
    </Window.InputBindings>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6"
                      CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource InkSecondaryBrush}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{DynamicResource SidebarBgBrush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Image Source="Assets/app.ico" Width="18" Height="18"/>
                    <TextBlock Text="PaperNote" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="{DynamicResource InkBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="FocusButton" Style="{StaticResource TitleBarButton}" ToolTip="Focus note (F11)"
                            Content="&#xE73F;" FontFamily="Segoe MDL2 Assets" FontSize="13" Click="OnToggleFocus"/>
                    <Button x:Name="MinButton" Style="{StaticResource TitleBarButton}" Content="&#xE921;"
                            FontFamily="Segoe MDL2 Assets" FontSize="10" Click="OnMinimize"/>
                    <Button x:Name="MaxButton" Style="{StaticResource TitleBarButton}" Content="&#xE922;"
                            FontFamily="Segoe MDL2 Assets" FontSize="10" Click="OnMaximizeRestore"/>
                    <Button x:Name="CloseBtn" Style="{StaticResource CloseButton}" Content="&#xE8BB;"
                            FontFamily="Segoe MDL2 Assets" FontSize="10" Click="OnClose"/>
                </StackPanel>
            </Grid>

            <!-- 3-pane body -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="205" MinWidth="160"/>
                    <ColumnDefinition x:Name="SidebarSplitterColumn" Width="Auto"/>
                    <ColumnDefinition x:Name="NoteListColumn" Width="300" MinWidth="240"/>
                    <ColumnDefinition x:Name="NoteListSplitterColumn" Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="320"/>
                </Grid.ColumnDefinitions>

                <views:SidebarView x:Name="SidebarPane" Grid.Column="0"/>
                <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="1" HorizontalAlignment="Stretch"
                              Background="{DynamicResource LineBrush}"/>
                <views:NoteListView x:Name="NoteListPane" Grid.Column="2"/>
                <GridSplitter x:Name="NoteListSplitter" Grid.Column="3" Width="1" HorizontalAlignment="Stretch"
                              Background="{DynamicResource LineBrush}"/>
                <views:EditorView Grid.Column="4"/>
            </Grid>

            <!-- Command palette (Ctrl+K) -->
            <Border x:Name="PaletteOverlay" Grid.Row="0" Grid.RowSpan="2"
                    Background="#33000000"
                    Visibility="{Binding IsPaletteOpen, Converter={StaticResource BoolToVis}}"
                    IsVisibleChanged="OnPaletteVisibleChanged"
                    PreviewMouseDown="OnPaletteBackdropClick">
                <Border Width="560" MaxHeight="440" VerticalAlignment="Top" Margin="0,120,0,0"
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="{StaticResource PanelRadius}"
                        BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="28" ShadowDepth="6" Direction="270"/>
                    </Border.Effect>
                    <StackPanel Margin="0">
                        <TextBox x:Name="PaletteBox"
                                 Text="{Binding PaletteQuery, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="OnPaletteKeyDown"
                                 Margin="16,16,16,8" Padding="6" FontSize="16"
                                 BorderThickness="0" Background="Transparent"
                                 Foreground="{DynamicResource InkBrush}"
                                 CaretBrush="{StaticResource AccentBrush}"/>
                        <Border Height="1" Background="{DynamicResource LineBrush}"/>
                        <ListBox x:Name="PaletteList"
                                 ItemsSource="{Binding PaletteResults}"
                                 SelectedItem="{Binding SelectedPaletteItem, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 MaxHeight="360" Margin="8"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 PreviewMouseLeftButtonUp="OnPaletteItemClick">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="row" Background="Transparent"
                                                        CornerRadius="{StaticResource ControlRadius}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="row" Property="Background" Value="{DynamicResource SelectedBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="row" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Glyph}" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="16" VerticalAlignment="Center"
                                                   Width="28" Foreground="{StaticResource AccentDeepBrush}"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Label}" FontSize="14"
                                                       Foreground="{DynamicResource InkBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                                       Foreground="{DynamicResource InkTertiaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
