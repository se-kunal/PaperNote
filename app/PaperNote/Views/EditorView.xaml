<UserControl x:Class="PaperNote.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="{DynamicResource PaperBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- editor surface -->
        <wv2:WebView2 x:Name="Web" Grid.Row="0" DefaultBackgroundColor="#FFFFFF"/>

        <!-- tag bar: GitHub-style pills, only for an open note -->
        <Border x:Name="TagBar" Grid.Row="1" Background="{DynamicResource PaperBrush}"
                BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0" Padding="14,9"
                Visibility="{Binding CanTagCurrentNote, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                           Foreground="{DynamicResource InkTertiaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ItemsControl ItemsSource="{Binding CurrentNoteTags}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="11" Margin="0,0,6,0" Padding="9,2"
                                    Background="{DynamicResource SelectedBrush}"
                                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding}" FontSize="12"
                                               Foreground="{StaticResource AccentDeepBrush}" VerticalAlignment="Center"/>
                                    <Button Margin="6,0,0,0" Cursor="Hand" ToolTip="Remove tag"
                                            Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                           Foreground="{StaticResource AccentDeepBrush}" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBox x:Name="NewTagBox" Width="120" MinWidth="80" BorderThickness="0" Background="Transparent"
                         FontSize="12" VerticalContentAlignment="Center" Foreground="{DynamicResource InkBrush}"
                         Text="{Binding NewTagText, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding AddTagCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <TextBlock Text="+ tag" Foreground="{DynamicResource InkTertiaryBrush}" FontSize="12"
                           IsHitTestVisible="False" Margin="-118,0,0,0" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NewTagText}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- empty state -->
        <Border x:Name="EmptyState" Background="{DynamicResource PaperBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="64" Height="64" CornerRadius="16" HorizontalAlignment="Center"
                        Background="{StaticResource AccentGradientBrush}">
                    <Border Width="28" Height="34" Background="White" CornerRadius="3"/>
                </Border>
                <TextBlock Text="Nothing here yet" FontSize="15" Margin="0,18,0,0"
                           HorizontalAlignment="Center" Foreground="{DynamicResource InkSecondaryBrush}"/>
                <TextBlock Text="start writing…" FontFamily="/PaperNote;component/Assets/Fonts/#Caveat" FontSize="28" Margin="0,2,0,0"
                           HorizontalAlignment="Center" Foreground="{StaticResource AccentDeepBrush}"/>
                <TextBlock Margin="0,14,0,0" HorizontalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource InkTertiaryBrush}">
                    Press <Run FontWeight="SemiBold" Foreground="{DynamicResource InkSecondaryBrush}">Ctrl N</Run> for a new note
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
