<Window x:Class="PaperNote.Views.ShareOfferDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shared note"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        FontFamily="{StaticResource UiFont}">
    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12"
            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="28" ShadowDepth="6" Direction="270"/>
        </Border.Effect>
        <StackPanel Width="320">
            <TextBlock x:Name="Headline" FontSize="15" Foreground="{DynamicResource InkBrush}" TextWrapping="Wrap"/>
            <TextBlock x:Name="Sub" Text="You'll get a copy in your Shared folder." FontSize="12" Margin="0,6,0,18"
                       Foreground="{DynamicResource InkTertiaryBrush}" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Reject" Click="OnReject" Cursor="Hand" Padding="14,7" Margin="0,0,8,0"
                        Background="Transparent" BorderThickness="0" Foreground="{DynamicResource InkSecondaryBrush}"/>
                <Button Content="Accept" Click="OnAccept" Cursor="Hand" Padding="16,7" Foreground="White" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="7" Background="{StaticResource AccentBrush}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentDeepBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
