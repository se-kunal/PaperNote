<Window x:Class="PaperNote.Views.PasswordPrompt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PaperNote"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        FontFamily="{StaticResource UiFont}">
    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12"
            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="28" ShadowDepth="6" Direction="270"/>
        </Border.Effect>
        <StackPanel Width="320">
            <TextBlock x:Name="Heading" Text="Lock note" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource InkBrush}"/>
            <TextBlock x:Name="Subhead" FontSize="12" Margin="0,4,0,16"
                       Foreground="{DynamicResource InkTertiaryBrush}" TextWrapping="Wrap"/>

            <PasswordBox x:Name="PwdBox" Padding="10,9" FontSize="14"
                         VerticalContentAlignment="Center"
                         Background="{DynamicResource PaperBrush}" Foreground="{DynamicResource InkBrush}"
                         BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                         PasswordChanged="OnChanged" KeyDown="OnKeyDown"/>

            <PasswordBox x:Name="ConfirmBox" Padding="10,9" FontSize="14" Margin="0,10,0,0"
                         VerticalContentAlignment="Center"
                         Background="{DynamicResource PaperBrush}" Foreground="{DynamicResource InkBrush}"
                         BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                         PasswordChanged="OnChanged" KeyDown="OnKeyDown"/>

            <TextBlock x:Name="ErrorText" FontSize="12" Margin="0,10,0,0" Foreground="#E11D48"
                       TextWrapping="Wrap" Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Click="OnCancel" Cursor="Hand" Padding="14,7" Margin="0,0,8,0"
                        Background="Transparent" BorderThickness="0" Foreground="{DynamicResource InkSecondaryBrush}"/>
                <Button x:Name="OkBtn" Content="Lock" Click="OnOk" Cursor="Hand"
                        Padding="14,7" Foreground="White" BorderThickness="0" IsEnabled="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="7" Background="{StaticResource AccentBrush}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentDeepBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
